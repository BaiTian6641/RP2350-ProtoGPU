/**
 * @file headless_selftest.cpp
 * @brief Headless self-test — renders ProtoGL scenes on SSD1331 OLED.
 *
 * Uses the full ProtoGL GPU rendering pipeline (SceneState, Rasterizer) to
 * draw meshes defined in memory and display the result on a 96×64 SSD1331
 * OLED panel.
 *
 * Scene contents:
 *   - Mesh 0: A single triangle (3 vertices, 1 face)
 *   - Mesh 1: A cube (8 vertices, 12 faces)
 *   - Material 0: Gradient (red→green→blue) along Y axis (for the triangle)
 *   - Material 1: Normal-map material (for the cube — shows face orientation)
 *   - Material 2: Solid cyan (second small triangle)
 *   - Camera 0: Perspective camera, positioned along +Z looking at origin
 *
 * The triangle sits on the left, the rotating cube on the right, and a small
 * solid-cyan triangle sits below the cube.  FPS and CPU usage are overlaid.
 *
 * Only compiled when RP2350GPU_HEADLESS_SELFTEST is defined.
 */

#ifdef RP2350GPU_HEADLESS_SELFTEST

#include "headless_selftest.h"
#include "ssd1331_driver.h"
#include "../gpu_config.h"
#include "../scene_state.h"
#include "../render/rasterizer.h"
#include "../math/pgl_math.h"

#include "pico/stdlib.h"

#include <cstdio>
#include <cstring>
#include <cmath>

// ─── Display Constants ──────────────────────────────────────────────────────

static constexpr uint16_t W = GpuConfig::SSD1331_WIDTH;   // 96
static constexpr uint16_t H = GpuConfig::SSD1331_HEIGHT;  // 64
static constexpr uint32_t FB_PIXELS = W * H;

// ─── Framebuffer & Z-buffer ─────────────────────────────────────────────────

static uint16_t g_fb[FB_PIXELS];
static uint16_t g_zb[FB_PIXELS];

// ─── Scene & Rasterizer ─────────────────────────────────────────────────────

static SceneState  g_scene;
static Rasterizer  g_rasterizer;

// ─── RGB565 Helper ──────────────────────────────────────────────────────────

static inline uint16_t Rgb565(uint8_t r, uint8_t g, uint8_t b) {
    return ((uint16_t)(r >> 3) << 11) |
           ((uint16_t)(g >> 2) <<  5) |
           ((uint16_t)(b >> 3));
}

